---
import { getCollection } from "astro:content";
import BlogCard from "./BlogCard.astro";

interface PostItem {
  id: string;
  data: {
    title: string;
    description: string;
    pubDate: Date;
    heroImage?: string;
    category: string;
    planId?: string;
  };
}

interface Props {
  posts: PostItem[];
  columns?: 1 | 2 | 3;
  allPosts?: PostItem[];
}

const { posts, columns = 3, allPosts = [] } = Astro.props;

const gridCols = {
  1: "grid-cols-1",
  2: "grid-cols-1 md:grid-cols-2",
  3: "grid-cols-1 md:grid-cols-2 lg:grid-cols-3",
};

const planEntries = await getCollection("plans");

function getCategoryIndex(
  postId: string,
  planId: string | undefined,
  category: string,
): number {
  const plan = planEntries.find((p) => p.data.skill === category);
  if (plan?.data.planOrder && planId) {
    const idx = plan.data.planOrder.indexOf(planId);
    if (idx !== -1) return idx + 1;
  }
  // fallback: 按 pubDate 排序位置
  return (
    allPosts
      .filter((p) => p.data.category === category)
      .findIndex((p) => p.id === postId) + 1
  );
}
---

<div class={`grid ${gridCols[columns]} gap-8`}>
  {
    posts.map((post) => (
      <BlogCard
        title={post.data.title}
        excerpt={post.data.description}
        date={post.data.pubDate}
        slug={post.id}
        image={post.data.heroImage}
        category={post.data.category}
        categoryIndex={getCategoryIndex(
          post.id,
          post.data.planId,
          post.data.category,
        )}
      />
    ))
  }
</div>
