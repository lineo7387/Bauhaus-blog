---
// No server-side imports needed — search UI is fully client-side
---

<div class="header-search">
  <!-- Search trigger button -->
  <button
    class="search-toggle p-2 border-2 border-foreground bg-surface-raised hover:bg-muted transition-colors text-text btn-press"
    aria-label="Open search"
  >
    <svg class="w-6 h-6 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="square" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
    </svg>
  </button>

  <!-- Search modal overlay -->
  <div
    class="search-modal fixed inset-0 z-[100] hidden"
    aria-modal="true"
    role="dialog"
  >
    <!-- Backdrop -->
    <div
      class="search-backdrop absolute inset-0 bg-surface-overlay"
    ></div>

    <!-- Modal panel -->
    <div class="relative z-10 flex items-start justify-center pt-[10vh] px-4">
      <div
        class="w-full max-w-2xl max-h-[80vh] flex flex-col bg-surface-raised border-4 border-foreground shadow-hard-lg"
      >
        <!-- Modal header -->
        <div class="flex items-center justify-between px-4 py-3 border-b-4 border-foreground bg-brand-yellow shrink-0">
          <span class="font-black uppercase text-sm tracking-widest text-foreground">
            Search
          </span>
          <button
            class="search-close p-1 hover:bg-foreground/10 transition-colors"
            aria-label="Close search"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="square" stroke-width="2.5" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

        <!-- Search content — Pagefind UI inlined to avoid SSR Rollup issues -->
        <div class="p-4 overflow-y-auto flex-1 pagefind-search-container">
          <div
            class="pagefind-ui"
            data-pagefind-ui
          ></div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  import { PagefindUI } from "@pagefind/default-ui";

  function initPagefindSearch(container: Element) {
    if ((container as HTMLElement).dataset.pagefindInitialized) return;

    new PagefindUI({
      element: container as unknown as string,
      bundlePath: `${import.meta.env.BASE_URL}pagefind/`,
    });

    (container as HTMLElement).dataset.pagefindInitialized = "true";
  }

  function initSearch() {
    const toggles = document.querySelectorAll(".search-toggle");
    if (!toggles.length) return;

    function findModal(el: Element) {
      return el.closest(".header-search")?.querySelector(".search-modal") ?? null;
    }

    function openModal(modal: Element | null) {
      if (!modal) return;
      modal.classList.remove("hidden");
      document.body.style.overflow = "hidden";
      const container = modal.querySelector(".pagefind-ui");
      if (container) initPagefindSearch(container);
      const input = modal.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
      setTimeout(() => input?.focus(), 50);
    }

    function closeModal(modal: Element | null) {
      if (!modal) return;
      modal.classList.add("hidden");
      document.body.style.overflow = "";
    }

    // Each toggle opens the modal in its own .header-search parent
    toggles.forEach(toggle => {
      toggle.addEventListener("click", () => {
        const modal = findModal(toggle);
        openModal(modal);
      });
    });

    document.querySelectorAll(".search-close").forEach(btn => {
      btn.addEventListener("click", (e) => closeModal(findModal(e.target as Element)));
    });

    document.querySelectorAll(".search-backdrop").forEach(bp => {
      bp.addEventListener("click", (e) => closeModal(findModal(e.target as Element)));
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape") {
        document.querySelectorAll(".search-modal:not(.hidden)").forEach(m => {
          m.classList.add("hidden");
          document.body.style.overflow = "";
        });
      }
    });
  }

  document.addEventListener("astro:page-load", initSearch);
</script>
